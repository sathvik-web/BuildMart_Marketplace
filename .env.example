# ============================================================
# BuildMart — Environment Variables (Phase 2)
# Copy to .env — never commit .env to git.
# ============================================================

# ── App ──────────────────────────────────────────────────────
NODE_ENV=development
API_PORT=3001
CORS_ORIGIN=http://localhost:3000

# ── Cookies ──────────────────────────────────────────────────
# Must be >= 32 random chars. Generate: openssl rand -base64 32
COOKIE_SECRET=replace_with_32plus_random_chars_openssl_rand_base64_32
COOKIE_DOMAIN=localhost

# ── Database ─────────────────────────────────────────────────
POSTGRES_USER=buildmart
POSTGRES_PASSWORD=buildmart_dev_secret
POSTGRES_DB=buildmart_dev
POSTGRES_PORT=5432
DATABASE_URL="postgresql://buildmart:buildmart_dev_secret@localhost:5432/buildmart_dev?schema=public"

# ── Redis ────────────────────────────────────────────────────
REDIS_PORT=6379
REDIS_URL="redis://localhost:6379"

# ── JWT ──────────────────────────────────────────────────────
# Must be >= 64 chars. Generate: openssl rand -base64 64
JWT_SECRET=replace_with_64plus_random_chars
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=replace_with_another_64plus_random_chars
REFRESH_TOKEN_EXPIRES_IN=30d

# ── Rate Limiting ────────────────────────────────────────────
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=60

# ── Firebase Admin (server-side OTP verification) ────────────
FIREBASE_PROJECT_ID=your-firebase-project-id
# Get from Firebase Console → Project Settings → Service Accounts
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com

# ── Twilio (optional fallback SMS OTP) ───────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ── pgAdmin (dev tools only) ─────────────────────────────────
PGADMIN_EMAIL=admin@buildmart.local
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5050

# ── Next.js Web ──────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=

# ── Razorpay ─────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXX
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_ACCOUNT_NUMBER=

# ── WhatsApp Business API ────────────────────────────────────
WHATSAPP_API_URL=https://graph.facebook.com/v19.0
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=

# ── File Storage (Cloudflare R2) ─────────────────────────────
STORAGE_PROVIDER=r2
STORAGE_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=
STORAGE_BUCKET_NAME=buildmart-dev
STORAGE_PUBLIC_URL=https://assets.buildmart.in

# ── Platform ─────────────────────────────────────────────────
PLATFORM_FEE_PERCENT=2.00
GEO_FENCE_RADIUS_KM=50
HYDERABAD_LAT=17.3850
HYDERABAD_LNG=78.4867
