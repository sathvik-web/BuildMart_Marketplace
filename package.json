{
  "name": "buildmart",
  "version": "1.0.0",
  "private": true,
  "description": "BuildMart — Construction Procurement Marketplace for Hyderabad",
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "turbo dev",
    "dev:web": "turbo dev --filter=@buildmart/web",
    "dev:api": "turbo dev --filter=@buildmart/api",
    "build": "turbo build",
    "build:web": "turbo build --filter=@buildmart/web",
    "build:api": "turbo build --filter=@buildmart/api",
    "lint": "turbo lint",
    "test": "turbo test",
    "test:e2e": "turbo test:e2e",
    "type-check": "turbo type-check",
    "db:generate": "turbo db:generate",
    "db:migrate": "turbo db:migrate",
    "db:migrate:dev": "turbo db:migrate:dev",
    "db:studio": "turbo db:studio",
    "db:seed": "turbo db:seed",
    "db:reset": "turbo db:reset",
    "docker:up": "docker compose up -d",
    "docker:up:tools": "docker compose --profile tools up -d",
    "docker:down": "docker compose down",
    "docker:down:volumes": "docker compose down -v",
    "docker:logs": "docker compose logs -f",
    "docker:ps": "docker compose ps",
    "docker:nuke": "docker compose down -v --remove-orphans",
    "setup": "pnpm install && pnpm docker:up && sleep 5 && pnpm db:generate && pnpm db:migrate:dev && pnpm db:seed",
    "clean": "turbo clean && find . -name 'node_modules' -type d -prune -exec rm -rf '{}' +",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.3.0",
    "@commitlint/config-conventional": "^19.2.2",
    "@types/node": "^22.5.0",
    "husky": "^9.1.4",
    "joi": "^17.13.3",
    "prettier": "^3.3.3",
    "turbo": "^2.1.3",
    "typescript": "^5.5.4"
  },
  "pnpm": {
    "overrides": {
      "prisma": "^5.18.0",
      "@prisma/client": "^5.18.0"
    }
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "prettier": {
    "semi": true,
    "singleQuote": false,
    "trailingComma": "all",
    "printWidth": 90,
    "tabWidth": 2
  }
}